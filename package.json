{
  "name": "starfield",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "author": "Alex Marshall",
  "scripts": {
    "build:catalog": "tsx scripts/build-catalog.ts",
    "build:clouds": "python3 scripts/build-clouds.py",
    "build:dust-sync": "tsx scripts/sync-dust.ts",
    "build:client": "vite build",
    "build": "npm run build:catalog && npm run build:clouds && npm run build:dust-sync && npm run build:client",
    "dev": "npm run build:catalog && npm run build:clouds && npm run build:dust-sync && vite",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fuse.js": "^7.0.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/node": "^20.10.0",
    "@types/three": "^0.160.0",
    "csv-parse": "^5.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wrangler": "^4.84.1"
  }
}
