node_modules/
dist/
.wrangler/
.vite/
.claude/
.DS_Store
*.log
coverage/

# Generated catalog artifacts (regenerated from source CSV)
public/catalog.bin
public/constellations.json
public/search-index.json
public/clouds.json
public/local-group.json

# Mirror of data/dust/ — the canonical LFS-tracked copy lives in data/dust/;
# scripts/build-dust.py copies chunks here so Vite's publicDir serves them.
public/dust/

# Raw-resample cache for build-dust.py. ~512 MiB float32 grid; lets us
# re-encode without re-running the 10-minute query phase. Local-only.
data/dust/.voxels.npy

# Python venv for scripts/build-dust.py and Phase 1 refresh scripts
.venv/

# Python bytecode cache (refresh_lib gets imported by refresh_lib.test.py)
scripts/__pycache__/


# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
